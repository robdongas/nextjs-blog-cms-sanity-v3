---
import { PortableText } from '@portabletext/react'

interface Props {
  title: string
  description?: any[]
  level: 1 | 2
}

const { title, description, level } = Astro.props
---

{level === 1 ? (
  <header class="mb-10 mt-8 flex flex-col items-center md:mb-12 md:flex-row md:justify-between text-pretty">
    <h1 class="text-5xl font-bold leading-tight tracking-tighter md:pr-8 md:text-4xl">
      {title}
    </h1>
    <span class="text-center text-lg md:pl-8 md:text-left portable-text">
      {description && <PortableText value={description} client:load />}
    </span>
  </header>
) : (
  <header class="mb-10 mt-8 flex flex-col items-center md:mb-12 md:flex-row md:justify-between text-pretty">
    <h1 class="text-5xl font-bold leading-tight tracking-tighter md:pr-8 md:text-4xl">
      <a href="/" class="hover:underline">
        {title}
      </a>
    </h1>
  </header>
)}

<style>
  .portable-text :global(a) {
    text-decoration: underline;
  }
</style>
