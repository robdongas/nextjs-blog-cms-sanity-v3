---
import { PortableText } from '@portabletext/react'
import { getClient, getSettings } from '../lib/sanity.client'

const client = getClient()
const settings = await getSettings(client)
const siteTitle = settings?.title || 'Ilana Bodenstein'
const description = settings?.description
const currentPath = Astro.url.pathname
---

<header class="w-full py-6">
  <div class="container mx-auto px-5">
    <div class="flex items-center justify-between w-full">
        <a
          href="/"
          class="text-lg font-bold tracking-tighter hover:underline shrink-0"
        >
          {siteTitle}
        </a>
        <nav>
          <ul class="flex gap-8">
            <li>
              <a
                href="/about"
                class:list={[
                  'text-sm tracking-wide uppercase transition-opacity hover:opacity-60',
                  {
                    'underline underline-offset-4':
                      currentPath === '/about' || currentPath === '/about/',
                  },
                ]}
              >
                About
              </a>
            </li>
          </ul>
        </nav>
        <a
          href="https://www.instagram.com/ilana.bode/"
          target="_blank"
          rel="noopener noreferrer"
          class="transition-opacity hover:opacity-60"
          aria-label="Instagram"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
          </svg>
        </a>

      <!-- <span class="text-sm portable-text hidden md:block">
        {description && <PortableText value={description} client:load />}
      </span> -->
    </div>
  </div>
</header>

<style>
  .portable-text :global(a) {
    text-decoration: underline;
  }
</style>
