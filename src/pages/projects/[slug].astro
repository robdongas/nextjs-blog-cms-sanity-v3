---
export const prerender = true

import '../../styles/tailwind.css'
import '../../styles/globals.css'

import BaseLayout from '../../layouts/BaseLayout.astro'
import BlogContainer from '../../components/BlogContainer.astro'
import ProjectHeader from '../../components/ProjectHeader.astro'
import SectionSeparator from '../../components/SectionSeparator.astro'
import ProjectBody from '../../components/ProjectBody.tsx'
import MoreStories from '../../components/MoreStories.tsx'

import { getClient, getSettings, getAllProjectsSlugs, getProjectAndMoreStories } from '../../lib/sanity.client'
import { urlForImage } from '../../lib/sanity.image'
import * as demo from '../../lib/demo.data'

import type { GetStaticPaths } from 'astro'

export const getStaticPaths = (async () => {
  const slugs = await getAllProjectsSlugs()
  const client = getClient()

  return await Promise.all(
    slugs.map(async ({ slug }) => {
      const [settings, { project, moreProjects }] = await Promise.all([
        getSettings(client),
        getProjectAndMoreStories(client, slug!),
      ])
      return {
        params: { slug },
        props: { project, moreProjects, settings },
      }
    })
  )
}) satisfies GetStaticPaths

const { project, moreProjects, settings } = Astro.props
const { title = demo.title } = settings || {}

// Build OG image
const ogImage = project.coverImage?.asset?._ref
  ? urlForImage(project.coverImage).width(1200).height(627).fit('crop').url()
  : undefined

const pageTitle = project.title ? `${project.title} | ${title}` : title
---

<BaseLayout title={pageTitle} ogImage={ogImage}>
  <BlogContainer>
    <article>
      <ProjectHeader
        title={project.title}
        coverImage={project.coverImage}
        coverHidden={project.coverHidden}
        date={project.date}
      />
      <ProjectBody content={project.content} client:load />
    </article>
    <SectionSeparator />
    {moreProjects?.length > 0 && <MoreStories projects={moreProjects} level={2} client:visible />}
  </BlogContainer>
</BaseLayout>
